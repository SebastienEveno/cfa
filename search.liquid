---
layout: null
---
{
  "results": [
    {% for post in site.pages %}{% if post.path contains 'study/' and post.name != 'search.liquid' %}{
      "title": "{{ post.title | default: post.name | escape }}",
      "url": "{{ post.url | relative_url }}",
      "content": {{ post.content | markdownify | strip_html | jsonify }},
      "path": "{{ post.path }}"
    }{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}
  ]
}
