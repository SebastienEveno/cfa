---
layout: null
---
{
  "results": [
    {% for page in site.pages %}{% if page.path contains 'study/' %}{
      "title": "{{ page.title | default: page.name | escape }}",
      "url": "{{ page.url }}",
      "content": {{ page.content | markdownify | strip_html | jsonify }}
    }{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}
  ]
}
